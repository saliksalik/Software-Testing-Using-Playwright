{
  "name": "salik-22k4403-adactin-automation",
  "version": "1.0.0",
  "description": "Playwright automation suite for Adactin Hotel App",
  "private": true,
  "scripts": {
    "test": "playwright test",
    "test:e2e": "playwright test tests/e2e",
    "test:e2e:headed": "playwright test tests/e2e/e2e_booking.spec.js --headed --workers=1",
    "test:e2e:record": "playwright test tests/e2e/e2e_booking.spec.js --headed --workers=1 --reporter=list",
    "test:positive": "playwright test tests/positive",
    "test:negative": "playwright test tests/negative",
    "test:headed": "playwright test --headed",
    "report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.0"
  }
}