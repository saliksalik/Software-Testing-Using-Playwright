{
  "openapi": "3.0.0",
  "info": {
    "title": "Posts API Contract",
    "version": "1.0.0"
  },
  "paths": {
    "/posts/{id}": {
      "get": {
        "responses": {
          "200": {
            "description": "Post response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "userId": { "type": "number" },
                    "id": { "type": "number" },
                    "title": { "type": "string" },
                    "body": { "type": "string" }
                  },
                  "required": ["userId", "id", "title", "body"]
                }
              }
            }
          }
        }
      }
    }
  }
}
